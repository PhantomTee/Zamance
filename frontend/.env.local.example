# URL of the Zamance bot backend (see ../bot)
NEXT_PUBLIC_BOT_API_URL=http://localhost:3001

# Optional: a real Zamance-branded looping hero video. Falls back to a
# gradient background when unset - see components/landing/HeroBackground.tsx
NEXT_PUBLIC_HERO_VIDEO_URL=

# Public, non-secret chain config for /balance (client-side confidential balance decrypt).
# Same values as the bot's WRAPPER_ADDRESS / RPC_URL - safe to expose, unlike a relayer API key.
NEXT_PUBLIC_WRAPPER_ADDRESS=0xBF525F705d2190BF4A58B82f07DD8676c65a9e9D
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
