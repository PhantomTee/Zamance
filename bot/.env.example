# Slack app (see ../README.md for manifest + OAuth setup)
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
# Any long random string - protects the OAuth state parameter
SLACK_STATE_SECRET=...
# Used for the separate "Sign in with Slack" (OIDC) dashboard login flow
SLACK_OIDC_REDIRECT_URI=http://localhost:3001/auth/slack/callback

# Chain (global - shared across all installed teams)
RPC_URL=https://sepolia.infura.io/v3/<YOUR_KEY>

# Real Circle Sepolia USDC and the one shared ConfidentialUSDCWrapper deployment
# (contracts/scripts/deployWrapper.ts) - protocol-level constants, NOT per-team config. Every
# team's Safe uses the same two addresses; balances inside the wrapper are isolated per-address.
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
WRAPPER_ADDRESS=0xBF525F705d2190BF4A58B82f07DD8676c65a9e9D

# Bot's own Safe co-signer key - ONE key used as an owner across every team's Safe.
# Never a per-team secret; being a Safe "owner" is just an on-chain permission grant.
BOT_SAFE_SIGNER_PRIVATE_KEY=0x...
# Get a Safe Transaction Service API key at https://developer.safe.global
SAFE_API_KEY=...

# DB - Postgres in every deployed environment (SQLite doesn't survive redeploys on
# most hosts). Render's Blueprint (render.yaml) wires this automatically; for local
# dev point it at any Postgres instance, e.g. a local `docker run postgres`.
DATABASE_URL=postgresql://user:password@localhost:5432/zamance

# Polling interval (ms) for the approval worker
APPROVAL_POLL_INTERVAL_MS=30000

# Optional - both default sensibly (see src/workers/keepAlive.ts). SELF_URL is this service's own
# public /healthz URL; only needed if the deployed hostname ever changes from zamance-bot.onrender.com.
# On Render's free tier, self-pinging on an interval keeps the container from spinning down after
# ~15 minutes idle, which would otherwise kill the Socket Mode connection Slack commands depend on.
# SELF_URL=https://zamance-bot.onrender.com/healthz
# KEEP_ALIVE_INTERVAL_MS=600000

# HTTP server for OAuth install + dashboard API routes
PORT=3001
# Origin of the DeLog frontend (CORS + OAuth redirect target)
DASHBOARD_ORIGIN=http://localhost:3000

# Signs dashboard session JWTs - any long random string
JWT_SECRET=...

# Parses "pay Sarah 500"-style DMs into structured payout intents (see src/ai/).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
