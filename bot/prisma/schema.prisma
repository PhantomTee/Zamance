datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// One row per Slack workspace that has installed DeLog. Doubles as the Slack Bolt
// InstallationStore backing table (see src/slack/installationStore.ts) and as the per-team
// treasury config. safeAddress is nullable because a team must connect a Safe from the
// dashboard after installing - DeLog cannot auto-deploy a Safe for them (that requires their
// own gas-funded key and their own on-chain deployment choices). There is deliberately no
// tokenAddress column:
// every team pays out in real Sepolia USDC plus one globally shared ConfidentialUSDCWrapper
// (WRAPPER_ADDRESS env var) - those are protocol-level constants, not per-team deployments.
model Team {
  id            String   @id // Slack team_id
  name          String?
  botToken      String
  botUserId     String?
  botScopes     String?
  installedAt   DateTime @default(now())
  safeAddress   String?

  wallets         Wallet[]
  verifiedOwners  VerifiedOwner[]
  payouts         Payout[]
  payrollRuns     PayrollRun[]
  auditLogs       AuditLog[]
}

model Wallet {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  slackUserId String
  ethAddress  String
  createdAt   DateTime @default(now())

  @@unique([teamId, slackUserId])
}

// A Wallet row (above) is just a self-reported "send my payouts here" address - the dashboard's
// wallet-registration flow reads it straight from a connected wallet, but nothing proves the
// caller actually controls that key. That's fine for receiving
// payouts, but it must NEVER be trusted to grant the "Safe owner" authorization the dashboard's
// fund-treasury action checks - a Slack user could otherwise register a real owner's public
// address as their own and pass that check without ever holding the key. VerifiedOwner is only
// written after a signature challenge (see POST /api/team/verify-owner in http/routes.ts) proves
// the caller actually controls the private key for that address.
model VerifiedOwner {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  slackUserId String
  ethAddress  String
  verifiedAt  DateTime @default(now())

  @@unique([teamId, slackUserId])
}

// Deliberately does NOT store the plaintext payout amount - the amount only ever exists
// in memory long enough to build the encrypted input, then it's discarded. Persisting it here
// would defeat the point of using a confidential token. amountHandle is the on-chain euint64
// ciphertext handle (an opaque bytes32); it is safe to store since it discloses nothing without
// the recipient's own decryption credentials. isPrivate only records which path was used
// (confidential wrapper vs plain USDC transfer) - it is never a substitute for the amount itself,
// and for public payouts the amount is genuinely public anyway (visible in the USDC transfer calldata).
model Payout {
  id            String      @id @default(cuid())
  teamId        String
  team          Team        @relation(fields: [teamId], references: [id])
  requesterId   String
  recipientId   String
  recipientAddr String
  isPrivate     Boolean     @default(true)
  amountHandle  String?
  safeTxHash    String?
  status        String      @default("pending_approval")
  txHash        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  payrollRunId  String?
  payrollRun    PayrollRun? @relation(fields: [payrollRunId], references: [id])
}

model PayrollRun {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  requesterId String
  isPrivate   Boolean  @default(true)
  safeTxHash  String?
  status      String   @default("pending_approval")
  txHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       Payout[]
}

// `detail` must never contain a plaintext payout amount - log payout/payroll IDs and
// addresses only, never the confidential value.
model AuditLog {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  actorId   String
  action    String
  detail    String
  createdAt DateTime @default(now())
}
