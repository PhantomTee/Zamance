{
  "display_information": {
    "name": "DeLog",
    "description": "Private team payouts on Ethereum Sepolia, encrypted with Zama FHEVM",
    "background_color": "#7342e2"
  },
  "features": {
    "bot_user": {
      "display_name": "delog",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/payout",
        "description": "Propose a single payout - toggle private/public in the modal",
        "should_escape": false
      },
      {
        "command": "/payroll",
        "description": "Propose a batch payroll run - toggle private/public in the modal",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://zamance-bot.onrender.com/slack/oauth_redirect",
      "https://zamance-bot.onrender.com/auth/slack/callback"
    ],
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "im:write",
        "im:history",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
